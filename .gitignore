# OS 생성 파일
.DS_Store
**/ .DS_Store
Thumbs.db
ehthumbs.db

# Python 캐시
__pycache__/
*.py[cod]
*$py.class

# 데이터/로그 (전체 제외 - 백업은 별도 관리)
data/
logs/

