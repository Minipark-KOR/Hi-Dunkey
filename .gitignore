venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*~

# 환경변수
.env
*.env

# 임시 파일
*.tmp
*.temp

# 오라클 보안키 파일(로컬작업시 사용)
echo "ssh-oracle.key" >> .gitignore
echo "ssh-oracle.key.pub" >> .gitignore